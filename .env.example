PORT=8000

# Database
DATABASE_URL=postgresql://

# Real external data providers
OWM_API_KEY=
WAQI_TOKEN=

# Optional real civic feeds for T5/T6 triggers
# Expected response shape: { "active": true|false, "official": true|false }
CURFEW_FEED_URL=
FESTIVAL_FEED_URL=

# Local source verification feed for community proposals
# Expected response shape: { "verified": true|false, "sources": string[] }
LOCAL_NEWS_FEED_URL=http://localhost:8000/feeds/local-news

# Optional upstream sources used by /feeds/local-news
NEWSDATA_API_KEY=
NEWSDATA_BASE_URL=https://newsdata.io/api/1/news
# Comma-separated RSS URLs (PIB/state/city feeds)
PIB_RSS_URLS=

# Real payout provider
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NO=

# Optional notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
